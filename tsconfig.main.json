{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "module": "Node16",
    "moduleResolution": "Node16",
    "lib": ["ES2023"],
    "types": ["node", "electron"],
    "rootDir": "src",
    "outDir": "dist-electron",
    "sourceMap": true
  },
  "include": [
    "src/main/**/*.ts",
    "src/preload/**/*.ts",
    "src/adapters/**/*.ts",
    "src/services/**/*.ts",
    "src/shared/**/*.ts"
  ],
  "exclude": ["src/**/*.test.ts", "src/renderer/**"]
}
